{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Topics registry",
  "type": "object",
  "required": ["topics"],
  "properties": {
    "topics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "curriculum", "questions_key"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "curriculum": { "type": "string", "pattern": "\\.json$" },
          "questions_key": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  }
}
