    "errorcorrection": {
      "title": "Practice: Correct the quantifier",
      "questions": [
        {
          "type": "open",
          "question": "Wrong: 'I have any milk.' Correct the sentence.",
          "answers": [
            "I have some milk.",
            "I have some milk"
          ],
          "explanation": "Positive → some, not any."
        },
        {
          "type": "open",
          "question": "Wrong: 'How much books did you read?' Correct the sentence.",
          "answers": [
            "How many books did you read?",
            "How many books did you read"
          ],
          "explanation": "Books = countable → many."
        },
        {
          "type": "open",
          "question": "Wrong: 'She has few friends.' (meaning she has some friends) Correct the sentence.",
          "answers": [
            "She has a few friends.",
            "She has a few friends"
          ],
          "explanation": "Positive (some) → a few."
        },
        {
          "type": "open",
          "question": "Wrong: 'I need a little eggs.' Correct the sentence.",
          "answers": [
            "I need a few eggs.",
            "I need a few eggs"
          ],
          "explanation": "Eggs = countable → a few."
        },
        {
          "type": "open",
          "question": "Wrong: 'There isn't some bread.' Correct the sentence.",
          "answers": [
            "There isn't any bread.",
            "There isn't any bread"
          ],
          "explanation": "Negative → any."
        },
        {
          "type": "open",
          "question": "Wrong: 'How many water do you need?' Correct the sentence.",
          "answers": [
            "How much water do you need?",
            "How much water do you need"
          ],
          "explanation": "Water = uncountable → much."
        },
        {
          "type": "open",
          "question": "Wrong: 'Less and less people are using public transport.' Correct the sentence.",
          "answers": [
            "Fewer and fewer people are using public transport.",
            "Fewer and fewer people are using public transport"
          ],
          "explanation": "People is countable → use **fewer**, not **less**. **Less** is for uncountable nouns (less time, less water); **fewer** is for countable nouns (fewer people, fewer books)."
        }
      ]
    }
  }
}
