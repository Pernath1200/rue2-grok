            "a": "some",
            "b": "any",
            "c": "many",
            "d": "few"
          },
          "correct_option": "a",
          "explanation": "Positive, uncountable → some."
        },
        {
          "type": "mc",
          "question": "Do you have _____ sugar?",
          "options": {
            "a": "some",
            "b": "any",
            "c": "much",
            "d": "many"
          },
          "correct_option": "b",
          "explanation": "Question → any."
        },
        {
          "type": "mc",
          "question": "How _____ people were at the party?",
          "options": {
            "a": "much",
            "b": "many",
            "c": "some",
            "d": "little"
          },
          "correct_option": "b",
          "explanation": "Countable (people) → many."
        },
        {
          "type": "mc",
          "question": "She has _____ friends in London.",
          "options": {
            "a": "few",
            "b": "a few",
            "c": "little",
            "d": "a little"
          },
          "correct_option": "b",
          "explanation": "Countable, positive (some) → a few."
        },
        {
          "type": "mc",
          "question": "There is _____ water left. (almost none)",
          "options": {
            "a": "little",
            "b": "a little",
            "c": "few",
            "d": "a few"
          },
          "correct_option": "a",
          "explanation": "Uncountable, negative (almost none) → little."
        },
        {
          "type": "mc",
          "question": "We have _____ time to finish. (some)",
          "options": {
            "a": "little",
            "b": "a little",
            "c": "many",
            "d": "much"
          },
          "correct_option": "b",
          "explanation": "Uncountable, positive (some) → a little."
        },
        {
          "type": "mc",
          "question": "_____ the students passed the exam.",
          "options": {
            "a": "All",
            "b": "Most",
            "c": "No",
            "d": "Any"
          },
          "correct_option": "a",
          "explanation": "The whole group → all."
        },
        {
          "type": "mc",
          "question": "I don't have _____ money.",
          "options": {
            "a": "some",
            "b": "any",
            "c": "many",
            "d": "few"
          },
          "correct_option": "b",
          "explanation": "Negative → any."
        },
        {
          "type": "mc",
          "question": "There are _____ apples on the table. (a small number)",
          "options": {
            "a": "few",
            "b": "a few",
            "c": "little",
            "d": "a little"
          },
          "correct_option": "b",
          "explanation": "Countable, positive → a few."
        },
        {
          "type": "mc",
          "question": "He has _____ experience in teaching.",
          "options": {
            "a": "much",
            "b": "many",
            "c": "a lot of",
            "d": "few"
          },
          "correct_option": "c",
          "explanation": "Positive statement, uncountable → a lot of."
