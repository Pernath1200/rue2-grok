{
  "intro": {
    "title": "Articles — extension (B2)",
    "sections": [
      {
        "title": "Abstract nouns — generic vs specific",
        "content": "Abstract uncountables take **no article** when used generally — but **the** when context makes them specific.",
        "diagrams": [
          {
            "type": "chips",
            "title": "Abstract uncountables",
            "items": [
              "love",
              "time",
              "music",
              "knowledge",
              "history"
            ]
          },
          {
            "type": "comparison",
            "title": "∅ general vs the specific",
            "left": {
              "title": "∅ general",
              "points": [
                "∅ **Love** is essential.",
                "∅ **History** repeats itself.",
                "∅ **Music** helps me concentrate."
              ]
            },
            "right": {
              "title": "the + specific",
              "points": [
                "**The love** she has for her children is incredible.",
                "**The history** of the Czech Republic is fascinating.",
                "**The music** in the café was too loud."
              ]
            }
          }
        ],
        "root_ids": [
          "B2.articles.advanced"
        ],
        "cefr_level": "B2"
      },
      {
        "title": "The + adjective for groups",
        "content": "Use **the + adjective** to refer to a whole group of people.\n\n*The rich should help the poor. The elderly deserve our respect.*",
        "diagrams": [
          {
            "type": "chips",
            "groups": [
              {
                "label": "social groups",
                "items": [
                  "the rich",
                  "the poor",
                  "the elderly",
                  "the homeless",
                  "the unemployed"
                ]
              },
              {
                "label": "nationalities in -ch / -sh / -ese",
                "items": [
                  "the French",
                  "the British",
                  "the Chinese",
                  "the Japanese"
                ]
              }
            ]
          }
        ],
        "root_ids": [
          "B2.articles.advanced"
        ],
        "cefr_level": "B2"
      },
      {
        "title": "Subjects of study and job titles",
        "content": "Subjects of study and *title + name* take **no article**; a unique role in context takes **the**.",
        "diagrams": [
          {
            "type": "table",
            "title": "Article or not?",
            "headers": [
              "Pattern",
              "Article",
              "Example"
            ],
            "rows": [
              [
                "subject of study",
                "∅",
                "study ∅ **history**, ∅ **economics**, ∅ **mathematics**, ∅ **chemistry**"
              ],
              [
                "title + name",
                "∅",
                "∅ **Doctor Smith**, ∅ **Professor Novák**, ∅ **President Obama**"
              ],
              [
                "unique role in context",
                "**the**",
                "**the** President, **the** Prime Minister, **the** Queen"
              ]
            ]
          },
          {
            "type": "examples",
            "title": "Compare: doctor three ways",
            "items": [
              {
                "good": "She's **a** doctor.",
                "why": "profession — one of many"
              },
              {
                "good": "∅ **Doctor Smith** is on holiday.",
                "why": "title + name"
              },
              {
                "good": "**The** doctor will see you now.",
                "why": "specific one"
              }
            ]
          }
        ],
        "root_ids": [
          "B2.articles.advanced"
        ],
        "cefr_level": "B2"
      },
