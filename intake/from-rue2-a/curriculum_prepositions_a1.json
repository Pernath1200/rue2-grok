{
  "intro": {
    "title": "Prepositions: in, on, at",
    "sections": [
      {
        "title": "Place: in, on, at",
        "content": "**in** = inside:\n• in the box, in the room, in London\n\n**on** = on top of:\n• on the table, on the floor\n\n**at** = at a place:\n• at home, at the door, at school"
      },
      {
        "title": "Time: in, on, at",
        "content": "**at** + clock time:\n• at 5 o'clock, at noon\n\n**on** + day:\n• on Monday, on Saturday\n\n**in** + month, year, or part of day:\n• in August, in 2020, in the morning"
      }
    ]
  },
  "check": {
    "title": "Check you understand",
