{
  "title": "Verb Patterns: to-infinitive, -ing & bare infinitive",
  "intro": "After some verbs we use only **to + verb** (to do). After others we use only **verb + -ing** (doing). Some verbs take both – with the same meaning or a different meaning. Below: examples with -ing, with to, and a short note.",
  "verbs": [
    { "verb": "want", "example_ing": "—", "example_to": "I want to learn English.", "wrong_ing": "I want learning English.", "note": "Only to-infinitive" },
    { "verb": "decide", "example_ing": "—", "example_to": "She decided to stay.", "wrong_ing": "I decided playing.", "note": "Only to-infinitive" },
    { "verb": "hope", "example_ing": "—", "example_to": "We hope to see you soon.", "wrong_ing": "We hope seeing you.", "note": "Only to-infinitive" },
    { "verb": "promise", "example_ing": "—", "example_to": "He promised to help.", "wrong_ing": "He promised helping.", "note": "Only to-infinitive" },
    { "verb": "agree", "example_ing": "—", "example_to": "They agreed to come.", "wrong_ing": "They agreed coming.", "note": "Only to-infinitive" },
    { "verb": "refuse", "example_ing": "—", "example_to": "He refused to answer.", "wrong_ing": "He refused answering.", "note": "Only to-infinitive" },
    { "verb": "offer", "example_ing": "—", "example_to": "She offered to drive.", "wrong_ing": "She offered driving.", "note": "Only to-infinitive" },
    { "verb": "manage", "example_ing": "—", "example_to": "They managed to finish on time.", "wrong_ing": "They managed finishing on time.", "note": "Only to-infinitive" },
    { "verb": "need", "example_ing": "—", "example_to": "You need to apply by Friday.", "wrong_ing": "You need applying by Friday.", "note": "Only to-infinitive (when meaning 'must')" },
    { "verb": "would like", "example_ing": "—", "example_to": "I'd like to try.", "wrong_ing": "I'd like trying.", "note": "Only to-infinitive" },
    { "verb": "enjoy", "example_ing": "I enjoy reading.", "example_to": "—", "wrong_to": "I enjoy to play.", "note": "Only -ing" },
    { "verb": "finish", "example_ing": "She finished writing the email.", "example_to": "—", "wrong_to": "She finished to write the email.", "note": "Only -ing" },
    { "verb": "avoid", "example_ing": "Avoid touching the wire.", "example_to": "—", "wrong_to": "Avoid to touch the wire.", "note": "Only -ing" },
    { "verb": "suggest", "example_ing": "He suggested going early.", "example_to": "—", "wrong_to": "He suggested to go early.", "note": "Only -ing" },
    { "verb": "mind", "example_ing": "Do you mind waiting?", "example_to": "—", "wrong_to": "Do you mind to wait?", "note": "Only -ing" },
    { "verb": "consider", "example_ing": "Consider taking a break.", "example_to": "—", "wrong_to": "Consider to take a break.", "note": "Only -ing" },
    { "verb": "keep", "example_ing": "Keep trying.", "example_to": "—", "wrong_to": "Keep to try.", "note": "Only -ing" },
    { "verb": "practise", "example_ing": "She practises singing.", "example_to": "—", "wrong_to": "She practises to sing.", "note": "Only -ing" },
    { "verb": "risk", "example_ing": "Don't risk losing it.", "example_to": "—", "wrong_to": "Don't risk to lose it.", "note": "Only -ing" },
    { "verb": "can't help", "example_ing": "I can't help laughing.", "example_to": "—", "wrong_to": "I can't help to laugh.", "note": "Only -ing" },
    { "verb": "look forward to", "example_ing": "I look forward to seeing you.", "example_to": "—", "wrong_to": "I look forward to see you.", "note": "Only -ing (to = preposition)" },
    { "verb": "like", "example_ing": "I like swimming.", "example_to": "I like to swim.", "note": "Both correct; same meaning" },
    { "verb": "love", "example_ing": "She loves dancing.", "example_to": "She loves to dance.", "note": "Both correct; same meaning" },
    { "verb": "hate", "example_ing": "I hate waiting.", "example_to": "I hate to wait.", "note": "Both correct; same meaning" },
    { "verb": "start", "example_ing": "It started raining.", "example_to": "It started to rain.", "note": "Both correct; same meaning" },
    { "verb": "begin", "example_ing": "She began working.", "example_to": "She began to work.", "note": "Both correct; same meaning" },
    { "verb": "continue", "example_ing": "He continued talking.", "example_to": "He continued to talk.", "note": "Both correct; same meaning" },
    { "verb": "prefer", "example_ing": "I prefer walking.", "example_to": "I prefer to walk.", "note": "Both correct; same meaning" },
    { "verb": "remember", "example_ing": "I remember meeting him. (recall past)", "example_to": "I remembered to lock the door. (not forget)", "note": "Both correct; different meaning" },
    { "verb": "forget", "example_ing": "I'll never forget visiting Paris. (recall)", "example_to": "Don't forget to call. (fail to do)", "note": "Both correct; different meaning" },
    { "verb": "stop", "example_ing": "She stopped smoking. (gave up)", "example_to": "She stopped to rest. (in order to)", "note": "Both correct; different meaning" },
    { "verb": "try", "example_ing": "Try adding salt. (experiment)", "example_to": "I tried to open it. (attempt)", "note": "Both correct; different meaning" },
    { "verb": "regret", "example_ing": "I regret saying that. (sorry about past)", "example_to": "I regret to inform you. (sorry to say)", "note": "Both correct; different meaning" },
    { "verb": "interested in", "example_ing": "I'm interested in learning.", "example_to": "—", "wrong_to": "I'm interested in to learn.", "note": "After preposition: -ing" },
    { "verb": "good at", "example_ing": "She's good at swimming.", "example_to": "—", "wrong_to": "She's good at to swim.", "note": "After preposition: -ing" },
    { "verb": "tired of", "example_ing": "I'm tired of waiting.", "example_to": "—", "wrong_to": "I'm tired of to wait.", "note": "After preposition: -ing" },
    { "verb": "without", "example_ing": "He left without saying goodbye.", "example_to": "—", "wrong_to": "He left without to say goodbye.", "note": "After preposition: -ing" },
    { "verb": "too + adjective", "example_ing": "—", "example_to": "It's too late to change. She's too young to drive.", "wrong_ing": "It's too late changing.", "note": "After too: to-infinitive" },
    { "verb": "enough", "example_ing": "—", "example_to": "She's old enough to vote. There's enough time to finish.", "wrong_ing": "She's old enough voting.", "note": "After enough: to-infinitive" }
  ]
}
