{
  "title": "Word Formation: Prefixes and Suffixes",
  "intro": "Common prefixes and suffixes for Part 3. **Prefixes** are listed from most to least common. **Suffixes** are in groups: noun, verb, adjective, adverb. Use this list to learn word families and to make the right word from the stem.",
  "prefixes": [
    {"prefix": "un-", "meaning": "not; opposite", "examples": "unable, unhappy, unlock"},
    {"prefix": "re-", "meaning": "again; back", "examples": "rewrite, return, rebuild"},
    {"prefix": "in- / im- / il- / ir-", "meaning": "not", "examples": "incorrect, impossible, illegal, irregular"},
    {"prefix": "dis-", "meaning": "not; opposite; apart", "examples": "disagree, disappear, dislike"},
    {"prefix": "en- / em-", "meaning": "cause to; put into", "examples": "enable, encourage, empower"},
    {"prefix": "pre-", "meaning": "before", "examples": "preview, prepay, prehistoric"},
    {"prefix": "over-", "meaning": "too much; above", "examples": "overflow, overload, oversleep"},
    {"prefix": "non-", "meaning": "not", "examples": "nonstop, nonfiction, nonsense"},
    {"prefix": "mis-", "meaning": "wrong; badly", "examples": "misunderstand, misuse, misspell"},
    {"prefix": "sub-", "meaning": "under; below", "examples": "subway, submarine, subtitle"},
    {"prefix": "inter-", "meaning": "between; among", "examples": "international, interact, internet"},
    {"prefix": "de-", "meaning": "reverse; remove", "examples": "defrost, decode, decrease"},
    {"prefix": "trans-", "meaning": "across; change", "examples": "transport, translate, transform"},
    {"prefix": "under-", "meaning": "too little; below", "examples": "underestimate, undercook, underpay"},
    {"prefix": "out-", "meaning": "more; beyond; external", "examples": "outdoors, outnumber, outgrow"},
    {"prefix": "post-", "meaning": "after", "examples": "postwar, postpone, postgraduate"},
    {"prefix": "super-", "meaning": "above; beyond", "examples": "supermarket, superstar, supernatural"},
    {"prefix": "fore-", "meaning": "before; front", "examples": "foresee, forearm, foreground"},
    {"prefix": "semi-", "meaning": "half; partly", "examples": "semicircle, semicolon, semiconductor"},
    {"prefix": "anti-", "meaning": "against", "examples": "anticlockwise, antibody, antisocial"},
    {"prefix": "mid-", "meaning": "middle", "examples": "midnight, midday, midweek"},
    {"prefix": "multi-", "meaning": "many", "examples": "multicultural, multiply, multimedia"},
    {"prefix": "ex-", "meaning": "former; out", "examples": "ex-president, ex-wife, export"},
    {"prefix": "self-", "meaning": "by oneself; for oneself", "examples": "self-service, selfish, self-esteem"},
    {"prefix": "co-", "meaning": "together; with", "examples": "cooperate, co-worker, coexist"},
    {"prefix": "counter-", "meaning": "opposite; in return", "examples": "counteract, counterargument, counterproductive"},
    {"prefix": "auto-", "meaning": "self; by itself", "examples": "automatic, autobiography, automobile"},
    {"prefix": "bi-", "meaning": "two; twice", "examples": "bicycle, bilingual, biannual"},
    {"prefix": "tri-", "meaning": "three", "examples": "triangle, tripod, tricycle"},
    {"prefix": "con- / com- / col-", "meaning": "with; together", "examples": "connect, combine, collect"}
  ],
  "suffixes": [
    {"suffix": "-ness", "partOfSpeech": "noun", "examples": "happiness, darkness, kindness"},
    {"suffix": "-tion", "partOfSpeech": "noun", "examples": "action, education, relation"},
    {"suffix": "-sion", "partOfSpeech": "noun", "examples": "decision, conclusion, television"},
    {"suffix": "-ment", "partOfSpeech": "noun", "examples": "movement, development, government"},
    {"suffix": "-er", "partOfSpeech": "noun (person/thing)", "examples": "teacher, writer, worker"},
    {"suffix": "-or", "partOfSpeech": "noun (person)", "examples": "actor, director, inventor"},
    {"suffix": "-ence", "partOfSpeech": "noun", "examples": "difference, reference, confidence"},
    {"suffix": "-ance", "partOfSpeech": "noun", "examples": "importance, distance, appearance"},
    {"suffix": "-ity", "partOfSpeech": "noun", "examples": "ability, quality, reality"},
    {"suffix": "-ship", "partOfSpeech": "noun", "examples": "friendship, leadership, membership"},
    {"suffix": "-ist", "partOfSpeech": "noun (person)", "examples": "artist, scientist, pianist"},
    {"suffix": "-ism", "partOfSpeech": "noun", "examples": "capitalism, tourism, criticism"},
    {"suffix": "-ty", "partOfSpeech": "noun", "examples": "safety, loyalty, certainty"},
    {"suffix": "-dom", "partOfSpeech": "noun", "examples": "freedom, kingdom, wisdom"},
    {"suffix": "-ize / -ise", "partOfSpeech": "verb", "examples": "organize, realise, apologise"},
    {"suffix": "-en", "partOfSpeech": "verb (or adjective)", "examples": "widen, strengthen, shorten"},
    {"suffix": "-ify", "partOfSpeech": "verb", "examples": "simplify, clarify, identify"},
    {"suffix": "-ate", "partOfSpeech": "verb", "examples": "create, communicate, celebrate"},
    {"suffix": "-ful", "partOfSpeech": "adjective", "examples": "wonderful, careful, beautiful"},
    {"suffix": "-less", "partOfSpeech": "adjective", "examples": "hopeless, careless, endless"},
    {"suffix": "-able", "partOfSpeech": "adjective", "examples": "comfortable, reliable, capable"},
    {"suffix": "-ible", "partOfSpeech": "adjective", "examples": "possible, visible, responsible"},
    {"suffix": "-al", "partOfSpeech": "adjective", "examples": "national, personal, musical"},
    {"suffix": "-ous", "partOfSpeech": "adjective", "examples": "dangerous, famous, nervous"},
    {"suffix": "-ive", "partOfSpeech": "adjective", "examples": "active, creative, effective"},
    {"suffix": "-y", "partOfSpeech": "adjective", "examples": "sunny, windy, sleepy"},
    {"suffix": "-ic", "partOfSpeech": "adjective", "examples": "romantic, economic, artistic"},
    {"suffix": "-ary", "partOfSpeech": "adjective", "examples": "necessary, voluntary, secondary"},
    {"suffix": "-ly", "partOfSpeech": "adverb", "examples": "quickly, happily, slowly"},
    {"suffix": "-ward(s)", "partOfSpeech": "adverb", "examples": "forward, backward, homeward"}
  ]
}
